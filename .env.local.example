# Optional: set when API is on another host (e.g. SSR). Leave unset to use /api (rewrites to backend).
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Backend URL for API rewrites (default: http://localhost:3000).
# To fix ECONNREFUSED: start the backend first: cd backend && npm run start:dev
# API_BACKEND_URL=http://localhost:3000
